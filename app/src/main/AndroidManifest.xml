<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 存储权限（仅 API 28 及以下需要，本项目 minSdk 29，保留声明以备兼容） -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- 设置壁纸等扩展功能 -->
    <uses-permission android:name="android.permission.SET_WALLPAPER" />

    <!-- 前台 Service（用于后台扫描任务） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- 网络权限（P4 远程仓库） -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- WifiLock 保持息屏后的局域网服务与 mDNS 可用 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- mDNS 多播锁（MulticastLock 必需，否则 mDNS 发现/注册失败） -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- 通知权限（Android 13+ 扫描进度通知） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 远程仓库当前依赖任意局域网 IPv4 地址，无法用静态域名白名单表达。
         因此保留明文 HTTP，但产品边界严格限定为用户信任的同一局域网。 -->
    <application
        android:name=".RemoPhotoApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.RemoPhoto.Splash"
        android:usesCleartextTraffic="true"
        android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.RemoPhoto.Splash"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Phase 4: HTTP Server 前台 Service（远程仓库服务端保活） -->
        <service
            android:name=".data.server.HttpServerForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!-- FileProvider：用于分享图片等文件 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
